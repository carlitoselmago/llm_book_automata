# Copy to /etc/llm-book.env (referenced by the systemd unit) and fill in.
# Every value here is optional except SECRET_KEY, which you should set.

# Stable secret so the book-session cookie survives restarts.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# OpenAI-compatible LLM backend (LM Studio, llama.cpp server, vLLM, ...).
# On a server this is rarely localhost of *this* box.
LM_STUDIO_BASE_URL=http://127.0.0.1:1234
LM_STUDIO_MODEL=liquid/lfm2.5-1.2b

# Where gunicorn listens (reverse proxy should sit in front for TLS).
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_THREADS=16

# Persistent data locations. outputs/ holds the library + generated PDFs —
# point it at a mounted volume you back up. Defaults to ./uploads and ./outputs.
# OUTPUT_FOLDER=/var/lib/llm-book/outputs
# UPLOAD_FOLDER=/var/lib/llm-book/uploads

# Max upload size in MB (Google Takeout zips can be large).
MAX_UPLOAD_MB=500
